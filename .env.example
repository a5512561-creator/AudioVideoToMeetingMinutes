# === 公司 LLM (OpenAI 相容) ===
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://internal-llm.company.com/v1
OPENAI_MODEL=gpt-4o-mini-equivalent

# === ASR (faster-whisper) ===
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=zh
WHISPER_INITIAL_PROMPT=以下是繁體中文會議記錄，可能包含英文技術名詞如 API、Roadmap、Sprint。
WHISPER_VAD_FILTER=true

# === Diarization (pyannote 3.1, 可選) ===
# 預設用 3.1 (Apache-2.0, free, 與 pyannote.audio 3.x 相容)。
# 若要換成更新的 Community-1，需自行升級 pyannote.audio 到 4.x 並解決
# torchcodec / k2 相依問題（Windows 上目前不易）。
ENABLE_DIARIZATION=false
HF_TOKEN=
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
ALIGNMENT_MODEL=jonatasgrosman/wav2vec2-large-xlsr-53-chinese-zh-cn

# === Transcript Correction (Stage 2.95, 可選) ===
ENABLE_PROPER_NOUN_CORRECTION=false
GLOSSARY_FILE=script/prompts/glossary.md

# === Chunking / LLM ===
LLM_CHUNK_TOKENS=4000
LLM_CHUNK_OVERLAP_RATIO=0.10
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECS=180
LLM_PARALLEL_MAP=3

# === Pricing (optional, only for cost-estimate display) ===
# Defaults 0 → only token volume is logged, no cost is shown.
# Examples (2026 公開牌價):
#   GPT-4o:       INPUT=2.5  OUTPUT=10
#   GPT-4o-mini:  INPUT=0.15 OUTPUT=0.6
#   Claude Sonnet 4.6: INPUT=3   OUTPUT=15
#   Gemini 2.5 Flash:  INPUT=0.075 OUTPUT=0.30
# 公司地端 LLM 如有 chargeback 費率，可在此填入。
LLM_PRICE_PER_1M_INPUT=0
LLM_PRICE_PER_1M_OUTPUT=0
LLM_CURRENCY=USD

# === I/O ===
OUT_DIR=out
LOG_DIR=log
LOG_LEVEL=INFO
KEEP_INTERMEDIATE=true
